    "modify": {
      "set-parameters": [
        {
          "param-id": "ac-07_odp.01",
          "values": [
            "three (3)"
          ],
          "remarks": "DoD CC SRG IL5 (NSS) - For privileged users; nonprivileged users limited to ten (10) attempts. AC-7(a)."
        },
        {
          "param-id": "ac-07_odp.02",
          "values": [
            "fifteen (15) minutes"
          ],
          "remarks": "DoD CC SRG IL5 (NSS) - AC-7(a) time period. Privileged users require administrator unlock; nonprivileged accounts auto-unlock after the specified period."
        },
        {
          "param-id": "au-05.01_odp.03",
          "values": [
            "seventy-five percent (75%)"
          ],
          "remarks": "DoD CC SRG IL5 (NSS) - CSP/CSO may use FedRAMP value. AU-5(1) repository capacity percentage."
        },
        {
          "param-id": "au-05.01_odp.02",
          "values": [
            "one month before expected negative impact"
          ],
          "remarks": "DoD CC SRG IL5 (NSS) - CSP/CSO may use FedRAMP value. AU-5(1) advance warning time period."
        },
        {
          "param-id": "cm-07.05_odp.02",
          "values": [
            "at least quarterly or when there is a change"
          ],
          "remarks": "DoD CC SRG IL5 (NSS) - CM-7(5)(c) review and update frequency for authorized software list."
        },
        {
          "param-id": "ia-05.01_odp.01",
          "values": [
            "at least quarterly"
          ],
          "remarks": "DoD CC SRG IL5 (NSS) - IA-5(1)(a) update frequency for commonly used / compromised passwords."
        },
        {
          "param-id": "ia-05.01_odp.02",
          "values": [
            "as supported by the device: minimum of 15 characters, 1 of each of the following character sets - upper-case, lower-case, numbers, special characters; modify at least 50% of the characters when new passwords are created"
          ],
          "remarks": "DoD CC SRG IL5 (NSS) - IA-5(1)(h) authenticator composition and complexity. Note: IL5 (NSS) requires 15 characters (vs. 12 for non-NSS IL5 from earlier SRG releases)."
        },
        {
          "param-id": "ma-06_odp.02",
          "values": [
            "a timeframe to support advertised uptime and availability"
          ],
          "remarks": "DoD CC SRG IL5 (NSS) - CSP/CSO may use FedRAMP value. MA-6 maintenance support time period."
        },
        {
          "param-id": "ps-03.04_odp.01",
          "values": [
            "all information types"
          ],
          "remarks": "DoD CC SRG IL5 (NSS) - PS-3(4) applies to all information systems / information types."
        },
        {
          "param-id": "ps-03.04_odp.02",
          "values": [
            "U.S. citizens, U.S. nationals, or U.S. persons; foreign personnel as allowed by current DoD policies with AO approval. Administrators must be U.S. citizens, U.S. nationals, or U.S. persons."
          ],
          "remarks": "DoD CC SRG IL5 (NSS) - PS-3(4) citizenship requirements."
        },
        {
          "param-id": "ps-04_odp.01",
          "values": [
            "one (1) hour"
          ],
          "remarks": "DoD CC SRG IL5 (NSS) - CSP/CSO may use FedRAMP High value of one (1) hour for system access disable on termination."
        },
        {
          "param-id": "sa-04.05_odp",
          "values": [
            "security configurations as identified by the applicable requirements from DoDI 8510.01 and STIGs/SRGs"
          ],
          "remarks": "DoD CC SRG IL5 (NSS) - SA-4(5)(a) DoD-mandated security configurations."
        },
        {
          "param-id": "sa-09.01_odp",
          "values": [
            "the DoD Component CIO or their delegate(s)"
          ],
          "remarks": "DoD CC SRG IL5 (NSS) - SA-9(1)(b) approval authority for external system service acquisition."
        },
        {
          "param-id": "sa-09.05_odp.01",
          "values": [
            "information processing",
            "information or data",
            "system services"
          ],
          "remarks": "DoD CC SRG IL5 (NSS) - SA-9(5)-1."
        },
        {
          "param-id": "sa-09.05_odp.02",
          "values": [
            "U.S./U.S. Territories or geographic locations where there is U.S. jurisdiction"
          ],
          "remarks": "DoD CC SRG IL5 (NSS) - SA-9(5)-2."
        },
        {
          "param-id": "sa-09.05_odp.03",
          "values": [
